VITE_KEYCLOAK_URL=https://keycloack.dfcubidesc.com
VITE_KEYCLOAK_REALM=habit-tracker
VITE_KEYCLOAK_CLIENT_ID=auth-service
# Callback goes to the BACKEND — it exchanges the code and sets the HTTPOnly cookie
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:8002/auth/login
VITE_API_BASE_URL=http://localhost:8001
# Backend auth service base URL used for session checks and logout
VITE_AUTH_BACKEND_URL=http://localhost:8002