@startuml seq-prd07-update-child-status
!theme plain
title PRD-07: PATCH /api/trips/{trip_id}/flights/{flight_id}/status — Request Sequence (Happy Path)

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam defaultFontSize 11

' ─────────────────────────────────────────────
' PARTICIPANTS
' ─────────────────────────────────────────────
actor "Trip Owner\n[Browser]" as User

box "fe-client\n[React SPA :3001]" #dae8fc
    participant "flightsOverview.tsx\n+ ChildStatusControl.tsx" as FE
    participant "TripService.ts\n(ApiTripService)" as TripSvc
end box

box "auth_service\n[FastAPI BFF :8002]" #dae8fc
    participant "ReverseProxy\n(httpx)" as Proxy
    participant "Redis\n[Session Store]" as Redis
end box

box "vacation_stay_scrapper\n[FastAPI :8000]" #dae8fc
    participant "routes.py\nPATCH .../flights/{id}/status" as Route
    participant "get_current_user\n[auth dependency]" as AuthDep
    participant "UpdateFlightStatusUseCase" as UseCase
    participant "Trip\n[aggregate root]" as Trip
    participant "FlightStatusTransitionValidator\n[domain service]" as Validator
    participant "Budget\n[value object]" as Budget
    participant "ITripRepository\n→ PostgresTripRepository" as Repo
end box

database "PostgreSQL" as PG #d5e8d4

' ─────────────────────────────────────────────
' FLOW
' ─────────────────────────────────────────────
User -> FE : Selects "Confirmed" from\nstatus dropdown on a flight card
note right of FE
  ChildStatusControl filters the
  dropdown to valid next states:
  childStatusTransitions[current]
end note

FE -> FE : Optimistic UI update\n(badge → "confirmed")

FE -> TripSvc : updateFlightStatus(tripId="42",\nflightId="f-9", "confirmed")
TripSvc -> Proxy : PATCH /vacation-planner/api/trips/42/flights/f-9/status\nBody: {"status": "confirmed"}\nCookie: session_id=<token>

Proxy -> Redis : GET session:<token>
Redis --> Proxy : JWT payload

Proxy -> Route : PATCH /api/trips/42/flights/f-9/status\nAuthorization: Bearer <JWT>\nBody: {"status": "confirmed"}

Route -> AuthDep : get_current_user(JWT)
AuthDep --> Route : {sub: "user-uuid-123", ...}

Route -> Route : ChildStatusUpdateRequest\n.validate(body)
Route -> UseCase : execute(\n  trip_id="42", flight_id="f-9",\n  new_status="confirmed",\n  owner_id="user-uuid-123"\n)

UseCase -> Repo : find_by_owner(42, "user-uuid-123")
Repo -> PG : SELECT * FROM trips\nWHERE id=42 AND owner_id=... (+ children)
PG --> Repo : TripModel row + child rows
Repo --> UseCase : Trip entity\n(flight f-9 status="pending")
note right of UseCase
  Owner resolved here.
  (See plan §7: non-owner →
  403 or 404 per decision.)
end note

UseCase -> Trip : update_flight_status("f-9", "confirmed")

Trip -> Trip : locate flight f-9\n(else raise ChildNotFound)
Trip -> Validator : validate(current="pending",\n            next="confirmed")
note right of Validator
  VALID_TRANSITIONS["pending"]
  = {"confirmed", "cancelled"}
  "confirmed" ∈ set → OK
end note
Validator --> Trip : (no exception)

Trip -> Trip : flight.status = "confirmed"

Trip -> Budget : recalculate_spent(\n  flights, accommodations, activities)
note right of Budget
  spent = Σ cost of
  confirmed flights +
  confirmed accommodations +
  booked activities
  (ADR-003). Returns new Budget.
end note
Budget --> Trip : new Budget(spent=...)
Trip -> Trip : self.budget = new Budget
Trip --> UseCase : (mutated Trip)

UseCase -> Repo : save(trip)
Repo -> PG : UPDATE flights SET status='confirmed'\nWHERE id='f-9'; UPDATE trips SET\nbudget_spent_amount=... WHERE id=42
PG --> Repo : committed
Repo --> UseCase : updated Trip entity

UseCase --> Route : updated Trip entity

Route -> Route : TripMapper.to_response(trip)
Route --> Proxy : HTTP 200\n{...full trip, flight f-9 status:"confirmed",\n budget.spent recalculated...}

Proxy --> TripSvc : HTTP 200 + updated trip JSON
TripSvc --> FE : updated Trip object

FE -> FE : Confirm optimistic update;\nre-render BudgetOverview from response
FE --> User : Flight badge shows "Confirmed" ✓\nBudget "Spent" updated

' ─────────────────────────────────────────────
' ALTERNATIVE: INVALID TRANSITION
' ─────────────────────────────────────────────
|||
== Alternative: Invalid Status Transition (422) ==
|||

FE -> TripSvc : updateFlightStatus("42","f-9","pending")\n(flight currently "confirmed")
note right of FE
  Frontend dropdown should not
  offer this; server validates
  as defense-in-depth.
end note
TripSvc -> Proxy : PATCH .../flights/f-9/status {"status":"pending"}
Proxy -> Route : (forwarded with JWT)
Route -> UseCase : execute("42","f-9","pending","user-uuid-123")
UseCase -> Repo : find_by_owner(42, ...)
Repo --> UseCase : Trip(flight f-9 status="confirmed")
UseCase -> Trip : update_flight_status("f-9","pending")
Trip -> Validator : validate("confirmed","pending")
note right of Validator
  "pending" ∉ VALID_TRANSITIONS["confirmed"]
  ( = {"cancelled"} )
  → raise InvalidStatusTransition
end note
Validator --> Trip : raises InvalidStatusTransition
Trip --> UseCase : propagates
UseCase --> Route : propagates
Route --> Proxy : HTTP 422 (via middleware)\n{"message":"Validation failed",\n"details":"Invalid transition: cannot\nmove from 'confirmed' to 'pending'"}
Proxy --> TripSvc : HTTP 422
TripSvc --> FE : Error
FE -> FE : Revert optimistic update\n(badge back to "confirmed")
FE --> User : Toast: "Status change failed"

@enduml
